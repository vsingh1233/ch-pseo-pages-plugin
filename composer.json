{
    "name": "ch/ch-pseo-pages-plugin",
    "description": "Development tooling for the CH-PSEO Pages WordPress plugin.",
    "type": "wordpress-plugin",
    "license": "GPL-2.0-or-later",
    "require": {
        "php": ">=7.4"
    },
    "require-dev": {
        "dealerdirect/phpcodesniffer-composer-installer": "^1.0",
        "phpcompatibility/phpcompatibility-wp": "^2.1",
        "phpstan/phpstan": "^1.12",
        "phpunit/phpunit": "^9.6",
        "szepeviktor/phpstan-wordpress": "^1.3",
        "wp-coding-standards/wpcs": "^3.0"
    },
    "config": {
        "allow-plugins": {
            "dealerdirect/phpcodesniffer-composer-installer": true
        },
        "platform": {
            "php": "7.4.0"
        },
        "sort-packages": true
    },
    "scripts": {
        "lint": "@php tools/lint.php",
        "phpcs": "@php vendor/bin/phpcs --standard=phpcs.xml.dist",
        "phpcbf": "@php vendor/bin/phpcbf --standard=phpcs.xml.dist",
        "phpstan": "@php vendor/bin/phpstan analyse --configuration=phpstan.neon.dist --memory-limit=1G",
        "test": "@php vendor/bin/phpunit --configuration=phpunit.xml.dist",
        "check": [
            "@lint",
            "@phpcs",
            "@phpstan",
            "@test"
        ]
    }
}
